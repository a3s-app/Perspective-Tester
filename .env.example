# Contact email — used for FormSubmit delivery, mailto links, and error messages.
# Defaults to Info@perspectivetester.com if not set.
NEXT_PUBLIC_CONTACT_EMAIL=Info@perspectivetester.com

# Resend API key for sending contact-form emails.
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) "From" address for Resend emails.
# Must be from a verified domain in Resend, or use the default testing sender.
# Defaults to onboarding@resend.dev if not set.
RESEND_FROM_EMAIL=notifications@yourdomain.com

# (Optional) Slack webhook for instant notifications when someone submits the form.
# Create one at: https://api.slack.com/messaging/webhooks
NEXT_PUBLIC_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
